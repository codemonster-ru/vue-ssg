    "@codemonster-ru/vueforge-layouts": "^1.10.0",
    "@codemonster-ru/vueiconify": "^1.3.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@unhead/vue": "^2.0.19",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
