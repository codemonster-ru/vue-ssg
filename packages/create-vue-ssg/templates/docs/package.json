{
  "name": "my-ssg-app",
  "version": "0.1.0",
  "private": true,
  "description": "Demo-style docs app for Codemonster SSG.",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "vue-tsc --noEmit && vite-ssg build",
