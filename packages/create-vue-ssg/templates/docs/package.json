    "typecheck": "vue-tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@codemonster-ru/vue-ssg-core": "^1.0.1",
    "@codemonster-ru/vue-codeblock": "^1.1.1",
