{
  "name": "@codemonster-ru/ssg-demo",
  "version": "0.1.1",
  "private": true,
  "description": "Demo app for Codemonster SSG packages.",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "vue-tsc --noEmit && vite-ssg build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@codemonster-ru/vue-ssg-core": "^1.0.5",
    "@codemonster-ru/vue-codeblock": "^2.0.0",
    "@codemonster-ru/vueforge-core": "^1.17.4",
    "@codemonster-ru/vueforge-layouts": "^1.10.0",
    "@codemonster-ru/vueiconify": "^1.3.1",
    "github-slugger": "^2.0.0",
    "marked": "^17.0.5",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
