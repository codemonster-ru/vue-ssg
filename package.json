{
  "name": "@codemonster-ru/vue-ssg",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for Codemonster SSG packages.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npm run -w @codemonster-ru/ssg-demo dev",
    "build": "npm run -w @codemonster-ru/ssg-demo build",
    "preview": "npm run -w @codemonster-ru/ssg-demo preview",
    "lint": "npm run -w @codemonster-ru/ssg-demo lint && npm run -w @codemonster-ru/vue-ssg-core lint && npm run -w @codemonster-ru/create-vue-ssg lint",
    "typecheck": "npm run -w @codemonster-ru/ssg-demo typecheck",
    "check": "npm run -w @codemonster-ru/ssg-demo check",
    "build:packages": "npm run -w @codemonster-ru/vue-ssg-core build",
    "typecheck:packages": "npm run -w @codemonster-ru/vue-ssg-core typecheck && npm run -w @codemonster-ru/create-vue-ssg typecheck",
    "pack:core": "npm pack --dry-run --workspace @codemonster-ru/vue-ssg-core",
    "pack:create-vue-ssg": "npm pack --dry-run --workspace @codemonster-ru/create-vue-ssg",
    "release:check": "npm run typecheck:packages && npm run build:packages && npm run pack:core && npm run pack:create-vue-ssg",
    "changeset": "changeset",
    "version:packages": "changeset version && node scripts/add-changelog-dates.mjs",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.1",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "typescript-eslint": "^8.57.2",
    "vue-eslint-parser": "^10.4.0"
  }
}
